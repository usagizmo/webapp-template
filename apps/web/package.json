{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --open",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint:markup": "markuplint \"**\"",
    "lint:js": "eslint .",
    "lint:cspell": "cspell \"**\"",
    "lint:prettier": "prettier . --check --ignore-path=../../.prettierignore",
    "lint": "run-p lint:*",
    "test:watch": "bun test --watch",
    "test": "bun test",
    "format:js": "eslint --fix .",
    "format:prettier": "prettier . --write --ignore-path=../../.prettierignore",
    "format": "run-p format:*"
  },
  "dependencies": {
    "@repo/shared": "workspace:*",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "catalog:",
    "api": "workspace:*",
    "camelcase-keys": "^10.0.2",
    "cdate": "catalog:",
    "snakecase-keys": "^9.0.2",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@internationalized/date": "catalog:",
    "@lucide/svelte": "catalog:",
    "@markuplint/svelte-parser": "^4.18.3",
    "@markuplint/svelte-spec": "^4.18.0",
    "@repo/eslint-config": "workspace:*",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "catalog:",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "bits-ui": "catalog:",
    "clsx": "catalog:",
    "formsnap": "catalog:",
    "mode-watcher": "catalog:",
    "npm-run-all2": "catalog:",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "svelte-sonner": "catalog:",
    "sveltekit-superforms": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwind-variants": "catalog:",
    "tailwindcss": "catalog:",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
