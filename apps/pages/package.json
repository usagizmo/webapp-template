{
  "name": "pages",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tailwindcss -i ./app.css -o ./public/styles.css --minify",
    "dev:tailwind": "tailwindcss -i ./app.css -o ./public/styles.css --watch",
    "dev:server": "browser-sync start --server ./public/ --files ./public/ --startPath /",
    "dev": "run-p dev:*",
    "lint:markup": "markuplint \"**\"",
    "lint:js": "eslint .",
    "lint:cspell": "cspell \"**\"",
    "lint:prettier": "prettier . --check --ignore-path=../../.prettierignore",
    "lint": "run-p lint:*",
    "test:watch": "bun test --watch",
    "test:update": "bun test --update-snapshots",
    "test": "bun test",
    "format:js": "eslint --fix .",
    "format:prettier": "prettier . --write --ignore-path=../../.prettierignore",
    "format": "run-p format:*",
    "add-size-to-img": "bun ./commands/add-size-to-img.js",
    "clean-images": "bun ./commands/clean-images.js",
    "deploy": "bun ./commands/deploy.js"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@tailwindcss/cli": "^4.3.1",
    "browser-sync": "^3.0.4",
    "eslint-plugin-jsdoc": "catalog:",
    "globals": "catalog:",
    "image-size": "^2.0.2",
    "npm-run-all2": "catalog:",
    "tailwindcss": "catalog:"
  }
}
