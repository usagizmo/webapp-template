{
  "name": "@repo/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "svelte-kit sync && svelte-package --watch",
    "build": "svelte-kit sync && svelte-package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint:markup": "markuplint \"**\"",
    "lint:js": "eslint .",
    "lint:cspell": "cspell \"**\"",
    "lint:prettier": "prettier . --check --ignore-path=../../.prettierignore",
    "lint": "run-p lint:*",
    "format:js": "eslint --fix .",
    "format:prettier": "prettier . --write --ignore-path=../../.prettierignore",
    "format": "run-p format:*"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "src",
    "!src/**/*.test.*",
    "!src/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./app.css": "./src/app.css",
    "./components/*.svelte": {
      "types": "./dist/components/*.svelte.d.ts",
      "svelte": "./src/lib/components/*.svelte",
      "default": "./dist/components/*.svelte"
    },
    "./components/ui/*": {
      "types": "./src/lib/components/ui/*/index.ts",
      "svelte": "./src/lib/components/ui/*/index.ts",
      "default": "./dist/components/ui/*/index.js"
    },
    "./constants/*": {
      "types": "./src/lib/constants/*.ts",
      "svelte": "./src/lib/constants/*.ts",
      "default": "./dist/constants/*.js"
    },
    "./helpers/*": {
      "types": "./src/lib/helpers/*.ts",
      "svelte": "./src/lib/helpers/*.ts",
      "default": "./dist/helpers/*.js"
    },
    "./schemas/*": {
      "types": "./src/lib/schemas/*.ts",
      "svelte": "./src/lib/schemas/*.ts",
      "default": "./dist/schemas/*.js"
    },
    "./types/*": {
      "types": "./src/lib/types/*.ts",
      "svelte": "./src/lib/types/*.ts",
      "default": "./dist/types/*.js"
    },
    "./utils/*": {
      "types": "./src/lib/utils/*.ts",
      "svelte": "./src/lib/utils/*.ts",
      "default": "./dist/utils/*.js"
    }
  },
  "peerDependencies": {
    "svelte": "^5.43.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "catalog:",
    "api": "workspace:*",
    "cdate": "catalog:",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@internationalized/date": "catalog:",
    "@lucide/svelte": "catalog:",
    "@repo/eslint-config": "workspace:*",
    "@sveltejs/kit": "catalog:",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "bits-ui": "catalog:",
    "clsx": "catalog:",
    "formsnap": "catalog:",
    "mode-watcher": "catalog:",
    "npm-run-all2": "catalog:",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "svelte-sonner": "catalog:",
    "sveltekit-superforms": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwind-variants": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
