{
  "name": "@repo/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "svelte-kit sync && svelte-package --watch",
    "build": "svelte-kit sync && svelte-package",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint:check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint:markup": "markuplint \"**\"",
    "lint:js": "eslint .",
    "lint:cspell": "cspell \"**\"",
    "lint:prettier": "prettier . --check --ignore-path=../../.prettierignore",
    "lint": "run-p lint:*",
    "format:js": "eslint --fix .",
    "format:prettier": "prettier . --write --ignore-path=../../.prettierignore",
    "format": "run-p format:*"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "src",
    "!src/**/*.test.*",
    "!src/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./app.css": "./src/app.css",
    "./components/*.svelte": {
      "types": "./dist/components/*.svelte.d.ts",
      "svelte": "./src/lib/components/*.svelte",
      "default": "./dist/components/*.svelte"
    },
    "./components/ui/*": {
      "types": "./src/lib/components/ui/*/index.ts",
      "svelte": "./src/lib/components/ui/*/index.ts",
      "default": "./dist/components/ui/*/index.js"
    },
    "./constants/*": {
      "types": "./src/lib/constants/*.ts",
      "svelte": "./src/lib/constants/*.ts",
      "default": "./dist/constants/*.js"
    },
    "./helpers/*": {
      "types": "./src/lib/helpers/*.ts",
      "svelte": "./src/lib/helpers/*.ts",
      "default": "./dist/helpers/*.js"
    },
    "./schemas/*": {
      "types": "./src/lib/schemas/*.ts",
      "svelte": "./src/lib/schemas/*.ts",
      "default": "./dist/schemas/*.js"
    },
    "./types/*": {
      "types": "./src/lib/types/*.ts",
      "svelte": "./src/lib/types/*.ts",
      "default": "./dist/types/*.js"
    },
    "./utils/*": {
      "types": "./src/lib/utils/*.ts",
      "svelte": "./src/lib/utils/*.ts",
      "default": "./dist/utils/*.js"
    }
  },
  "peerDependencies": {
    "svelte": "^5.43.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "api": "workspace:*",
    "cdate": "^0.0.7",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.18.0",
    "@repo/eslint-config": "workspace:*",
    "@sveltejs/kit": "^2.65.0",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "formsnap": "^2.0.1",
    "mode-watcher": "^1.1.0",
    "npm-run-all2": "^9.0.2",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "svelte-sonner": "^1.1.1",
    "sveltekit-superforms": "^2.30.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
